{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relay.dev/schemas/relay.view.v1.schema.json",
  "title": "Relay Context View v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "view_id",
    "source_capsule_id",
    "mode",
    "estimated_tokens",
    "sections"
  ],
  "properties": {
    "schema": {
      "const": "relay.view.v1"
    },
    "view_id": {
      "type": "string",
      "pattern": "^view_[a-zA-Z0-9_-]+$"
    },
    "source_capsule_id": {
      "type": "string",
      "pattern": "^ctx_[a-zA-Z0-9_-]+$"
    },
    "mode": {
      "type": "string",
      "enum": [
        "compact",
        "standard",
        "deep"
      ]
    },
    "estimated_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
